# ==============================================================================
# CodeSleuth — Fichier d'environnement template
# Copiez ce fichier en .env et renseignez vos propres valeurs.
# NE COMMITEZ JAMAIS votre .env dans Git !
# ==============================================================================

# --- GitHub API ---
# Token GitHub pour interroger les repos publics via l'API REST.
# Scopes minimaux requis : public_repo (lecture seule)
# Creer un token sur : https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# --- Modele LLM ---
# Modele Gemini a utiliser pour tous les agents du pipeline.
# Options recommandees :
#   gemini-2.5-flash  (defaut, quota gratuit limite)
#   gemini-2.5-pro    (meilleure qualite, quota plus restreint)
# Pour switcher : exportez CODESLEUTH_MODEL=gemini-2.5-pro
CODESLEUTH_MODEL=gemini-2.0-flash-lite

# --- Cle API Google (pour Gemini) ---
# Obtenez votre cle sur : https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Configuration optionnelle ---
# Timeout MCP en secondes (defaut : 30s)
# MCP_TIMEOUT=30
